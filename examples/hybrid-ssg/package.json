{
  "name": "example-hybrid-ssg",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "generate:routes": "node build/generate-routes.mjs",
    "dev:public": "vite",
    "dev:editor": "vite --config vite.config.editor.js",
    "build:public": "npm run generate:routes && vite build",
    "build:editor": "vite build --config vite.config.editor.js",
    "build": "npm run build:public && npm run build:editor"
  },
  "dependencies": {
    "vue": "^3.5.0",
    "vue-router": "^4.5.0",
    "mikser-io-sdk-api": "^2.2.0",
    "mikser-io-sdk-vue": "^1.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.0",
    "vite": "^6.0.0",
    "vite-ssg": "^0.24.0"
  }
}
