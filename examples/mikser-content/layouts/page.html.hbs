<!DOCTYPE html>
<html lang="{{meta.lang}}">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{meta.title}} — Acme Co</title>
</head>
<body>
    <header>
        <h2><a href="/">Acme Co</a></h2>
        <div data-island="cart-counter"></div>
    </header>

    <main>
        <h1>{{meta.title}}</h1>
        {{{content}}}
    </main>

    <aside>
        <h3>Search</h3>
        <div data-island="search" data-endpoint="public"></div>
    </aside>

    <!-- Island bundles produced by examples/islands' vite build.
         For scenarios A and B the rendered HTML isn't consumed; the
         Vue apps drive the UI from the api. -->
    <script type="module" src="/islands/search.js"></script>
    <script type="module" src="/islands/cart-counter.js"></script>
</body>
</html>
